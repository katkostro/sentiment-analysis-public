# Copy and fill in, then: source .env (bash) or load with python-dotenv
# All auth uses managed identity (DefaultAzureCredential) – no API keys needed
AZURE_AI_SERVICES_ENDPOINT=https://<your-ai-services-name>.cognitiveservices.azure.com/
AZURE_LANGUAGE_ENDPOINT=https://<your-language-name>.cognitiveservices.azure.com/
FOUNDRY_PROJECT_NAME=sentiment-analysis
GPT_DEPLOYMENT_NAME=gpt-4o

# Data source: 'local' (default) or 'fabric'
DATA_SOURCE=local

# Microsoft Fabric settings (only when DATA_SOURCE=fabric)
# FABRIC_ONELAKE_ENDPOINT=https://onelake.dfs.fabric.microsoft.com
# FABRIC_LAKEHOUSE_PATH=workspace-name/lakehouse-name/Files/surveys/file.xlsx
